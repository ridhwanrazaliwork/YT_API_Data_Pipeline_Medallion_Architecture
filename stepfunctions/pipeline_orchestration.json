{
  "Comment": "YouTube Data Pipeline — Full orchestration via Step Functions. Replaces manual execution of individual jobs.",
  "StartAt": "IngestFromYouTubeAPI",
  "States": {
    "IngestFromYouTubeAPI": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "arn:aws:lambda:ap-southeast-1:905418370529:function:dev-yt-ingestion:$LATEST",
        "Payload": {
          "triggered_by": "step_functions",
          "execution_id.$": "$$.Execution.Id"
        }
      },
      "ResultPath": "$.ingestion_result",
      "Retry": [
        {
          "ErrorEquals": [
            "Lambda.ServiceException",
            "Lambda.TooManyRequestsException"
          ],
          "IntervalSeconds": 30,
          "MaxAttempts": 3,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "Next": "NotifyIngestionFailure",
          "ResultPath": "$.error"
        }
      ],
      "Next": "WaitForS3Consistency"
    },
    "WaitForS3Consistency": {
      "Type": "Wait",
      "Seconds": 60,
      "Comment": "Brief wait to ensure S3 eventual consistency for newly written objects",
      "Next": "ProcessInParallel"
    },
    "ProcessInParallel": {
      "Type": "Parallel",
      "Comment": "Run reference data transform and statistics ETL in parallel",
      "Branches": [
        {
          "StartAt": "TransformReferenceData",
          "States": {
            "TransformReferenceData": {
              "Type": "Task",
              "Resource": "arn:aws:states:::lambda:invoke",
              "Parameters": {
                "FunctionName": "arn:aws:lambda:ap-southeast-1:905418370529:function:dev-yt-transform:$LATEST",
                "Payload": {
                  "triggered_by": "step_functions"
                }
              },
              "ResultPath": "$.reference_result",
              "Retry": [
                {
                  "ErrorEquals": [
                    "States.ALL"
                  ],
                  "IntervalSeconds": 60,
                  "MaxAttempts": 2,
                  "BackoffRate": 2
                }
              ],
              "End": true
            }
          }
        },
        {
          "StartAt": "RunBronzeToSilverGlueJob",
          "States": {
            "RunBronzeToSilverGlueJob": {
              "Type": "Task",
              "Resource": "arn:aws:states:::glue:startJobRun.sync",
              "Parameters": {
                "JobName": "dev-yt-data-pipeline-bronze-to-silver",
                "Arguments": {
                  "--bronze_database": "yt_pipeline_bronze_dev-v2",
                  "--bronze_table": "raw_statistics",
                  "--silver_bucket": "rid-yt-pipeline-silver-ap-southeast-1-dev-v2",
                  "--silver_database": "yt_pipeline_silver_dev-v2",
                  "--silver_table": "clean_statistics"
                }
              },
              "ResultPath": "$.glue_bronze_silver_result",
              "Retry": [
                {
                  "ErrorEquals": [
                    "States.ALL"
                  ],
                  "IntervalSeconds": 60,
                  "MaxAttempts": 2,
                  "BackoffRate": 2
                }
              ],
              "End": true
            }
          }
        }
      ],
      "ResultPath": "$.parallel_results",
      "Catch": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "Next": "NotifyTransformFailure",
          "ResultPath": "$.error"
        }
      ],
      "Next": "RunDataQualityChecks"
    },
    "RunDataQualityChecks": {
      "Type": "Task",
      "Resource": "arn:aws:states:::lambda:invoke",
      "Parameters": {
        "FunctionName": "arn:aws:lambda:ap-southeast-1:905418370529:function:dev-yt-quality:$LATEST",
        "Payload": {
          "layer": "silver",
          "database": "yt_pipeline_silver_dev-v2",
          "tables": [
            "clean_statistics",
            "clean_reference_data"
          ]
        }
      },
      "ResultPath": "$.dq_result",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 60,
          "MaxAttempts": 2,
          "BackoffRate": 2
        }
      ],
      "Next": "EvaluateDataQuality"
    },
    "EvaluateDataQuality": {
      "Type": "Choice",
      "Choices": [
        {
          "Variable": "$.dq_result.Payload.quality_passed",
          "BooleanEquals": true,
          "Next": "RunSilverToGoldGlueJob"
        }
      ],
      "Default": "NotifyDQFailure"
    },
    "RunSilverToGoldGlueJob": {
      "Type": "Task",
      "Resource": "arn:aws:states:::glue:startJobRun.sync",
      "Parameters": {
        "JobName": "dev-yt-data-pipeline-silver-to-gold",
        "Arguments": {
          "--silver_database": "yt_pipeline_silver_dev-v2",
          "--gold_bucket": "rid-yt-pipeline-gold-ap-southeast-1-dev-v2",
          "--gold_database": "yt_pipeline_gold_dev-v2"
        }
      },
      "ResultPath": "$.glue_gold_result",
      "Retry": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "IntervalSeconds": 60,
          "MaxAttempts": 2,
          "BackoffRate": 2
        }
      ],
      "Catch": [
        {
          "ErrorEquals": [
            "States.ALL"
          ],
          "Next": "NotifyGoldFailure",
          "ResultPath": "$.error"
        }
      ],
      "Next": "NotifySuccess"
    },
    "NotifySuccess": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:ap-southeast-1:905418370529:yt-data-pipeline-alerts-dev-v2",
        "Subject": "[YT Pipeline] Pipeline completed successfully",
        "Message": {
          "status": "SUCCESS",
          "pipeline_name": "youtube_data_pipeline",
          "timestamp": "example timestamp"
        }
      },
      "End": true
    },
    "NotifyIngestionFailure": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:ap-southeast-1:905418370529:yt-data-pipeline-alerts-dev-v2",
        "Subject": "[YT Pipeline] FAILURE — Ingestion step failed",
        "Message": {
          "status": "FAILURE",
          "layer": "BRONZE",
          "source": "s3-bucket-raw",
          "error": "error message from the step",
          "timestamp": "example timestamp"
        }
      },
      "End": true
    },
    "NotifyTransformFailure": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:ap-southeast-1:905418370529:yt-data-pipeline-alerts-dev-v2",
        "Subject": "[YT Pipeline] FAILURE — Transform step failed",
        "Message": {
          "status": "FAILURE",
          "stage": "TRANSFORM",
          "error": "error message from the step",
          "timestamp": "example timestamp"
        }
      },
      "End": true
    },
    "NotifyDQFailure": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:ap-southeast-1:905418370529:yt-data-pipeline-alerts-dev-v2",
        "Subject": "[YT Pipeline] WARNING — Data quality checks failed",
        "Message": {
          "status": "FAILURE",
          "check": "DATA_QUALITY",
          "reason": "Null values > threshold",
          "error": "error message from the step",
          "timestamp": "example timestamp"
        }
      },
      "End": true
    },
    "NotifyGoldFailure": {
      "Type": "Task",
      "Resource": "arn:aws:states:::sns:publish",
      "Parameters": {
        "TopicArn": "arn:aws:sns:ap-southeast-1:905418370529:yt-data-pipeline-alerts-dev-v2",
        "Subject": "[YT Pipeline] FAILURE — Gold aggregation failed",
        "Message": {
          "status": "FAILURE",
          "layer": "GOLD",
          "error": "error message from the step",
          "timestamp": "example timestamp"
        }
      },
      "End": true
    }
  }
}