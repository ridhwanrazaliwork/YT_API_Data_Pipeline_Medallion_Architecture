{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "S3FullAccess",
			"Effect": "Allow",
			"Action": [
				"s3:GetObject",
				"s3:PutObject",
				"s3:ListBucket",
				"s3:DeleteObject"
			],
			"Resource": [
				"arn:aws:s3:::rid-yt-pipeline-bronze-ap-southeast-1-dev/*",
				"arn:aws:s3:::rid-yt-pipeline-bronze-ap-southeast-1-dev/",
				"arn:aws:s3:::rid-yt-pipeline-silver-ap-southeast-1-dev/*",
				"arn:aws:s3:::rid-yt-pipeline-silver-ap-southeast-1-dev/",
				"arn:aws:s3:::rid-yt-pipeline-gold-ap-southeast-1-dev/*",
				"arn:aws:s3:::rid-yt-pipeline-gold-ap-southeast-1-dev/",
				"arn:aws:s3:::rid-yt-pipeline-script-ap-southeast-1-dev/*",
				"arn:aws:s3:::rid-yt-pipeline-script-ap-southeast-1-dev/"
			]
		}
	]
}